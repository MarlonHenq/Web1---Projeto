[Unit]
Description=Freelancers Spring Boot (Web1)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/freelancers
EnvironmentFile=-/var/www/freelancers/.env
ExecStart=/usr/bin/java -Xmx512m -jar /var/www/freelancers/app/FreelancersJPA.jar --spring.profiles.active=prod
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
